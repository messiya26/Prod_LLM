generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  STUDENT
  INSTRUCTOR
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  bio           String?
  role          Role         @default(STUDENT)
  emailVerified Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  enrollments   Enrollment[]
  contacts      ContactMessage[]
  courses       Course[]     @relation("instructor")
  payments      Payment[]
  notifications Notification[]
  bookings      Booking[]
  invitations   Invitation[] @relation("invitedBy")
  blogPosts     BlogPost[]   @relation("BlogAuthor")
  events        Event[]      @relation("EventAuthor")
  subscriptions Subscription[]
  masterclassesInstructed Masterclass[] @relation("MasterclassInstructor")
  masterclassRegistrations MasterclassRegistration[]

  @@map("users")
}

model Invitation {
  id          String   @id @default(cuid())
  email       String
  role        Role     @default(STUDENT)
  token       String   @unique
  invitedById String
  invitedBy   User     @relation("invitedBy", fields: [invitedById], references: [id])
  accepted    Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("invitations")
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  courses Course[]

  @@map("categories")
}

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String
  thumbnail    String?
  level        Level        @default(ALL_LEVELS)
  price        Decimal      @default(0)
  published    Boolean      @default(false)
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id])
  instructorId String?
  instructor   User?        @relation("instructor", fields: [instructorId], references: [id])
  modules      Module[]
  enrollments  Enrollment[]
  payments     Payment[]
  resources    CourseResource[]
  quiz         Quiz?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("courses")
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@map("modules")
}

model Lesson {
  id           String  @id @default(cuid())
  title        String
  order        Int
  content      String?
  muxAssetId   String?
  muxPlaybackId String?
  duration     Int?
  moduleId     String
  module       Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status    EnrollmentStatus @default(ACTIVE)
  progress  Int              @default(0)
  payments  Payment[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, courseId])
  @@map("enrollments")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PAYPAL
  STRIPE
  MOBILE_MONEY
  ILLICOCASH
  CASH_APP
  MPESA
  BANK_TRANSFER
  FREE
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  method        PaymentMethod @default(STRIPE)
  reference     String        @unique
  providerTxId  String?
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  enrollmentId  String?
  enrollment    Enrollment?   @relation(fields: [enrollmentId], references: [id])
  courseId      String
  course        Course        @relation(fields: [courseId], references: [id])
  metadata      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Booking {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  email     String
  phone     String?
  date      DateTime
  slot      String
  subject   String
  notes     String?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@map("bookings")
}

model AdminInvitation {
  id        String   @id @default(cuid())
  email     String
  role      Role     @default(INSTRUCTOR)
  token     String   @unique
  invitedBy String
  accepted  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("admin_invitations")
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  type      String   @default("EMAIL_VERIFICATION")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("verification_tokens")
}

model Certificate {
  id            String   @id @default(cuid())
  certificateId String   @unique
  userId        String
  courseId       String
  studentName   String
  courseName    String
  instructorName String?
  issuedAt      DateTime @default(now())
  grade         String?
  hoursCompleted Int     @default(0)
  verificationHash String @unique
  pdfUrl        String?

  @@index([userId])
  @@index([certificateId])
  @@map("certificates")
}

// ─── Phase B : Litterature & Quiz ──────────────────────────────────────────

enum ResourceType {
  PDF
  AUDIO
  VIDEO
  DOCUMENT
}

model CourseResource {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        ResourceType
  url         String
  fileSize    Int?
  duration    Int?
  order       Int          @default(0)
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("course_resources")
}

model Quiz {
  id           String         @id @default(cuid())
  title        String
  description  String?
  passingScore Int            @default(70)
  courseId     String         @unique
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(cuid())
  question      String
  options       String
  correctAnswer String
  explanation   String?
  order         Int      @default(0)
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers   String
  score     Int
  passed    Boolean
  createdAt DateTime @default(now())

  @@map("quiz_attempts")
}

model LessonProgress {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  enrollmentId String
  completed    Boolean  @default(false)
  watchedAt    DateTime @default(now())

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ─── Phase C : Sessions Live ────────────────────────────────────────────────

enum LivePlatform {
  JITSI
  ZOOM
  GOOGLE_MEET
}

enum LiveStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveSession {
  id            String       @id @default(cuid())
  title         String
  description   String?
  platform      LivePlatform @default(JITSI)
  status        LiveStatus   @default(SCHEDULED)
  meetingUrl    String?
  meetingId     String?
  roomName      String       @unique
  hostId        String
  courseId      String?
  maxAttendees  Int          @default(100)
  scheduledAt   DateTime
  startedAt     DateTime?
  endedAt       DateTime?
  duration      Int?
  replayUrl     String?
  attendees     LiveAttendee[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@map("live_sessions")
}

model LiveAttendee {
  id          String      @id @default(cuid())
  userId      String
  sessionId   String
  session     LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  joinedAt    DateTime    @default(now())
  leftAt      DateTime?

  @@unique([userId, sessionId])
  @@map("live_attendees")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  image       String?
  category    String   @default("general")
  tags        String?
  published   Boolean  @default(false)
  authorId    String
  author      User     @relation("BlogAuthor", fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  image       String?
  location    String?
  isOnline    Boolean  @default(false)
  link        String?
  date        DateTime
  endDate     DateTime?
  price       Float    @default(0)
  capacity    Int?
  registrations Int    @default(0)
  published   Boolean  @default(false)
  authorId    String
  author      User     @relation("EventAuthor", fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("text")
  updatedAt DateTime @updatedAt

  @@map("site_content")
}

enum SubscriptionPlan {
  FREE
  ESSENTIAL
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  plan        SubscriptionPlan   @default(FREE)
  status      SubscriptionStatus @default(ACTIVE)
  amount      Float              @default(0)
  currency    String             @default("USD")
  interval    String             @default("monthly")
  startDate   DateTime           @default(now())
  endDate     DateTime?
  cancelledAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("subscriptions")
}

model PricingPlan {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameFr        String
  nameEn        String
  descFr        String   @default("")
  descEn        String   @default("")
  monthlyPrice  Float    @default(0)
  annualPrice   Float    @default(0)
  currency      String   @default("USD")
  featuresFr    String   @default("[]")
  featuresEn    String   @default("[]")
  popular       Boolean  @default(false)
  isFree        Boolean  @default(false)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  ctaFr         String   @default("Choisir")
  ctaEn         String   @default("Choose")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing_plans")
}

enum MasterclassStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum MasterclassFormat {
  ONLINE
  IN_PERSON
  HYBRID
}

model Masterclass {
  id              String             @id @default(cuid())
  title           String
  titleEn         String             @default("")
  slug            String             @unique
  description     String
  descriptionEn   String             @default("")
  shortDesc       String             @default("")
  shortDescEn     String             @default("")
  thumbnail       String             @default("")
  bannerImage     String             @default("")
  category        String             @default("general")
  level           String             @default("all")
  format          MasterclassFormat  @default(ONLINE)
  status          MasterclassStatus  @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  dailyStartTime  String             @default("09:00")
  dailyEndTime    String             @default("17:00")
  timezone        String             @default("Africa/Kinshasa")
  location        String             @default("")
  meetingLink     String             @default("")
  price           Float              @default(0)
  currency        String             @default("USD")
  earlyBirdPrice  Float?
  earlyBirdEnd    DateTime?
  maxSeats        Int                @default(50)
  seatsLeft       Int                @default(50)
  instructorId    String?
  instructor      User?              @relation("MasterclassInstructor", fields: [instructorId], references: [id])
  programFr       String             @default("[]")
  programEn       String             @default("[]")
  whatYouLearnFr  String             @default("[]")
  whatYouLearnEn  String             @default("[]")
  prerequisites   String             @default("[]")
  includedFr      String             @default("[]")
  includedEn      String             @default("[]")
  testimonials    String             @default("[]")
  isFeatured      Boolean            @default(false)
  certificateIncluded Boolean        @default(true)
  replayAvailable Boolean            @default(true)
  registrations   MasterclassRegistration[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("masterclasses")
}

model MasterclassRegistration {
  id              String      @id @default(cuid())
  masterclassId   String
  masterclass     Masterclass @relation(fields: [masterclassId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          String      @default("PENDING")
  paymentRef      String?
  amountPaid      Float       @default(0)
  registeredAt    DateTime    @default(now())

  @@unique([masterclassId, userId])
  @@map("masterclass_registrations")
}
